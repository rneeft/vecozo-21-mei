@page
@model SignInModel
@{
  ViewData["Title"] = "Sign In";
}

<h2>Sign In</h2>

<form method="post">
  <div asp-validation-summary="All" class="text-danger"></div>
  <div class="form-group mb-3">
    <label asp-for="Bsn"></label>
    <input asp-for="Bsn" class="form-control" autocomplete="off" placeholder="Enter your BSN" />
    <span asp-validation-for="Bsn" class="text-danger"></span>
  </div>
  <div class="form-group mb-3">
    <label asp-for="LastName"></label>
    <input asp-for="LastName" class="form-control" autocomplete="off" placeholder="Enter your last name" />
    <span asp-validation-for="LastName" class="text-danger"></span>
  </div>
  <button type="submit" class="btn btn-primary">Sign In</button>
</form>